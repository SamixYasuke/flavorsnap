# Environment Configuration Template
# Copy this file to .env.local for development, .env.staging for staging, or .env.production for production

# Application Environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_SECRET_KEY=your-secret-key-here

# Database Configuration (if applicable)
DATABASE_URL=postgresql://username:password@localhost:5432/flavorsnap

# External Services
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=your-contract-id-here

# ML Model Configuration
MODEL_PATH=models/best_model.pth
MODEL_CLASSES_PATH=food_classes.txt

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif

# Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# Feature Flags
ENABLE_ML_CLASSIFICATION=true
ENABLE_BLOCKCHAIN_INTEGRATION=true
ENABLE_ANALYTICS=false

# Development Only
DEBUG_MODE=true
HOT_RELOAD=true
